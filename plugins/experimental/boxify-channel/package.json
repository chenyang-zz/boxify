{
  "name": "boxify-channel",
  "version": "0.1.0",
  "private": true,
  "description": "Boxify native OpenClaw channel",
  "type": "module",
  "main": "index.js",
  "license": "MIT",
  "peerDependencies": {
    "openclaw": ">=2026.3.1"
  },
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "channel": {
      "id": "boxify",
      "label": "Boxify",
      "selectionLabel": "Boxify",
      "docsPath": "/channels/boxify",
      "docsLabel": "boxify",
      "blurb": "Boxify local native channel for OpenClaw."
    },
    "install": {
      "localPath": "plugins/experimental/boxify-channel",
      "defaultChoice": "path"
    }
  }
}
